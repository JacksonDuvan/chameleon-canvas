# URLs del backend desplegado (Worker autoritativo del juego).
# OJO: las variables VITE_* se inyectan en BUILD TIME (vite build), NO en runtime.
# Por eso hay que tenerlas definidas ANTES de construir/desplegar el frontend.
#
# Flujo: despliega primero el backend (`pnpm backend:deploy`). Cloudflare te dará una
# URL tipo  https://chameleon-canvas-backend.<tu-subdominio>.workers.dev
# Copia este archivo a `.env.production` con TUS valores (http→https, ws→wss):
#
#   cp apps/frontend/.env.production.example apps/frontend/.env.production
#
# En CI (GitHub Actions) se pasan como secrets, no por este archivo.

VITE_API_URL=https://chameleon-canvas-backend.<tu-subdominio>.workers.dev
VITE_WS_URL=wss://chameleon-canvas-backend.<tu-subdominio>.workers.dev
