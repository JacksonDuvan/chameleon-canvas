{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../../packages/shared/src/*"],
      "@sim/*": ["../../packages/sim/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  // Las rutas de TanStack Start se tipan contra `routeTree.gen.ts`, que genera el
  // plugin en `vite dev`/`build`; el typecheck de rutas ocurre ahí. Se excluyen del
  // `tsc --noEmit` de producción (no hay codegen previo). El resto SÍ se typechquea.
  "exclude": ["src/routes/**", "src/router.tsx", "src/routeTree.gen.ts"]
}
