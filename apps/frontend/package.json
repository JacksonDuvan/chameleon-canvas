{
  "name": "@mecha/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cliente del juego: TanStack Start + React 19 + React Three Fiber (R3F v9) + Zustand vanilla. Predicción/interpolación sobre el kernel @mecha/sim.",
