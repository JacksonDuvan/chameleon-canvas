    "@react-three/drei": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@mecha/backend": "workspace:*",
    "@cloudflare/vite-plugin": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/three": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
