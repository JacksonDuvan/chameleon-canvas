# pnpm — configuración del monorepo (Meccha Chameleon Clone)

# Node 24 obligatorio: el requisito es funcionar ESTRICTAMENTE bajo Node 24.
# Esto hace que `pnpm install` falle si la versión de Node no cumple `engines`.
engine-strict=true

# Workspaces: enlaza siempre los paquetes internos del monorepo por symlink
# (no descarga desde el registro) y usa protocolo workspace al guardar deps.
link-workspace-packages=true
prefer-workspace-packages=true
save-workspace-protocol=rolling

# Peers: resuelve peers automáticamente y deduplica (clave con React/three/R3F).
auto-install-peers=true
dedupe-peer-dependents=true

# Determinismo de instalación.
resolution-mode=highest
