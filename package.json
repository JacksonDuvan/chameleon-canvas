{
  "name": "chameleon-canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Clon web 3D online inspirado en Meccha Chameleon — monorepo Cloudflare (Hono + Durable Objects + TanStack Start + R3F).",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:do": "pnpm --filter @mecha/backend test:do",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "backend:dev": "pnpm --filter @mecha/backend dev",
    "backend:deploy": "pnpm --filter @mecha/backend deploy",
    "frontend:dev": "pnpm --filter @mecha/frontend dev",
    "frontend:deploy": "pnpm --filter @mecha/frontend deploy",
    "cf-typegen": "pnpm --filter @mecha/backend cf-typegen"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-boundaries": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
